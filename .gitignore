# --- Dependencies ---
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# --- Next.js ---
/.next/
/out/
next-env.d.ts

# --- Production build ---
/build
/dist

# --- Environment variables (NEVER commit secrets / API keys) ---
.env
.env*.local
.env.development
.env.production
.env.test
# Keep the example file so others know what variables are needed
!.env.example
!.env.local.example

# --- Vercel ---
.vercel

# --- Testing / coverage ---
/coverage

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs
*.log

# --- TypeScript (harmless to keep even in a JS project) ---
*.tsbuildinfo

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo
*~

# --- Package manager locks you don't want clashing (keep only ONE) ---
# Uncomment if you standardize on a single package manager:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# --- Misc caches ---
.cache
.eslintcache
.turbo